# TotalRecall environment configuration template.
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.

# ---- Core ----
TOTALRECALL_ENVIRONMENT=development
TOTALRECALL_SERVICE_NAME=totalrecall

# ---- Database ----
# Local Postgres connection string
TOTALRECALL_DATABASE_URL=postgresql://totalrecall:totalrecall@localhost:5432/totalrecall
# Set to false to run without a database (stub/null adapters only)
TOTALRECALL_ENABLE_DATABASE=true

# ---- Auth ----
# JSON map of bearer tokens to tenant/actor/role config.
# For production use a secret manager reference instead of hardcoding here.
# Example: {"your-token-here":{"tenant_id":"tenant_acme","actor_id":"ci-runner","roles":["admin"]}}
TOTALRECALL_AUTH_TOKENS={}

# ---- Feature flags ----
# JSON map of feature flag keys to values.
# memory.adapter: stub | null | mem0_v1
# memory.shadow_adapter: (empty = disabled) | stub | null | mem0_v1
# Example: {"memory.adapter":"mem0_v1","memory.shadow_adapter":"stub"}
TOTALRECALL_FEATURE_FLAGS={"memory.adapter":"stub"}

# ---- Credentials ----
# JSON map of credential reference names to environment variable names or local file paths.
# Example for Mem0: {"mem0_api_key":"env:MEM0_API_KEY"}
# Example using a local secret file: {"mem0_api_key":"file:/run/secrets/mem0_api_key"}
# Example using an external secret-manager adapter: {"mem0_api_key":"cloud:mem0_api_key"}
TOTALRECALL_CREDENTIAL_REFS={}
# Set when using local file references above
TOTALRECALL_LOCAL_SECRETS_DIR=/run/secrets
# Optional HTTP adapter for Vault/AWS/GCP/Azure secret-manager sidecars or proxies.
# It must expose GET /secrets/{name} returning {"value":"..."} or plaintext.
TOTALRECALL_EXTERNAL_CREDENTIAL_BASE_URL=
TOTALRECALL_EXTERNAL_CREDENTIAL_AUTH_TOKEN=
TOTALRECALL_EXTERNAL_CREDENTIAL_TIMEOUT_SECONDS=5

# The actual secret values referenced above (not stored in this file in production)
# MEM0_API_KEY=your-mem0-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# ---- Cache ----
# TTL for in-memory search result cache (seconds)
TOTALRECALL_CACHE_TTL_SECONDS=300

# ---- Rate limits ----
# JSON map of tenant_id (or "default") to per-tenant rate limit policy.
# Example: {"default":{"max_requests":60,"window_seconds":60},"tenant_acme":{"max_requests":200,"window_seconds":60}}
TOTALRECALL_RATE_LIMITS={}

# ---- External feature flags ----
# Optional OpenFeature-compatible HTTP endpoint returning {"values": {...}} or a raw flag object.
TOTALRECALL_EXTERNAL_FEATURE_FLAGS_URL=
TOTALRECALL_EXTERNAL_FEATURE_FLAGS_AUTH_TOKEN=
TOTALRECALL_EXTERNAL_FEATURE_FLAGS_TIMEOUT_SECONDS=5
TOTALRECALL_EXTERNAL_FEATURE_FLAGS_CACHE_TTL_SECONDS=30

# ---- Skills ----
# Directory containing skill JSON definition files
TOTALRECALL_SKILLS_DIR=skills

# ---- Playwright validation worker ----
# Optional JSON array command. Leave empty to skip TypeScript worker validation.
# Example: ["node","workers/playwright/dist/cli.js"]
TOTALRECALL_PLAYWRIGHT_WORKER_COMMAND=[]
TOTALRECALL_PLAYWRIGHT_WORKER_TIMEOUT_SECONDS=10

# ---- Memory wrapper service ----
# Optional standalone deployment target:
# uv run uvicorn totalrecall.memory.service_app:app --host 0.0.0.0 --port 8001
